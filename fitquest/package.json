{
  "name": "fitquest",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bash scripts/node22.sh node_modules/vite/bin/vite.js",
    "build": "bash scripts/node22.sh node_modules/vite/bin/vite.js build",
    "preview": "bash scripts/node22.sh node_modules/vite/bin/vite.js preview",
    "cap:sync": "bash scripts/node22.sh node_modules/@capacitor/cli/bin/capacitor sync",
    "build:native": "npm run build && npm run cap:sync",
    "build:apk": "bash scripts/build-android-debug.sh",
    "open:ios": "bash scripts/node22.sh node_modules/@capacitor/cli/bin/capacitor open ios",
    "open:android": "bash scripts/node22.sh node_modules/@capacitor/cli/bin/capacitor open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/ios": "^8.3.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.3",
    "vite": "^6.3.5"
  }
}
